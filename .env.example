# Private family login emails.
JIYOOL_EMAIL=jiyool@example.com
HAYOOL_EMAIL=hayool@example.com
PARENT_EMAIL=parent@example.com
SESSION_SECRET=replace-with-a-random-string

# Supabase server-side connection.
# Use the new Supabase secret key if available, or the legacy service_role key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx

# OpenAI Responses API.
OPENAI_API_KEY=sk-proj-xxx
OPENAI_EVALUATION_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
